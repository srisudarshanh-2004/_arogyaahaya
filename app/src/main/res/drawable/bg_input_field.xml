<?xml version="1.0" encoding="utf-8"?>
<!-- Rounded border for EditText input fields — clean and easy to tap -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <corners android:radius="8dp"/>
    <stroke
        android:width="1.5dp"
        android:color="@color/grey_medium"/>
    <solid android:color="@color/background_primary"/>
    <padding
        android:left="12dp"
        android:top="4dp"
        android:right="12dp"
        android:bottom="4dp"/>
</shape>
